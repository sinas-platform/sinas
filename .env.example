# ============================================================================
# REQUIRED
# ============================================================================

# Security — auto-generated by install.sh
SECRET_KEY=your-secret-key
ENCRYPTION_KEY=your-fernet-key
DATABASE_PASSWORD=your-secure-password

# SMTP (required for OTP login emails)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-api-key
SMTP_DOMAIN=example.com

# Admin — first user, added to Admins role on startup
SUPERADMIN_EMAIL=admin@example.com

# Domain — set for production (enables auto-HTTPS via Caddy)
DOMAIN=localhost

# ============================================================================
# OPTIONAL — sensible defaults, override as needed
# ============================================================================

# Database (defaults work with the bundled postgres container)
# DATABASE_USER=postgres
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_NAME=sinas
# DATABASE_URL=postgresql://user:password@host:5432/sinas  # overrides individual vars

# Redis
# REDIS_URL=redis://redis:6379/0

# Debug
# DEBUG=false

# CORS (comma-separated origins, defaults to none)
# CORS_ORIGINS=https://yourdomain.com

# JWT tokens
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
# OTP_EXPIRE_MINUTES=10
# OTP_MAX_ATTEMPTS=2

# Rate limiting
# RATE_LIMIT_LOGIN_IP_MAX=10
# RATE_LIMIT_LOGIN_EMAIL_MAX=5
# RATE_LIMIT_OTP_IP_MAX=10
# RATE_LIMIT_WINDOW_SECONDS=900

# Function execution (Docker containers)
# FUNCTION_TIMEOUT=300
# MAX_FUNCTION_MEMORY=512
# MAX_FUNCTION_CPU=1.0
# MAX_FUNCTION_STORAGE=1g
# FUNCTION_CONTAINER_IDLE_TIMEOUT=3600
# ALLOW_PACKAGE_INSTALLATION=true
# ALLOWED_PACKAGES=                      # comma-separated whitelist, empty = all

# Sandbox containers
# SANDBOX_MIN_SIZE=4
# SANDBOX_MAX_SIZE=20
# SANDBOX_MIN_IDLE=2
# SANDBOX_MAX_EXECUTIONS=100

# Agent processing
# MAX_TOOL_ITERATIONS=25
# MAX_HISTORY_MESSAGES=100
# AGENT_JOB_TIMEOUT=600
# CODE_EXECUTION_TIMEOUT=120

# Queue workers
# QUEUE_FUNCTION_CONCURRENCY=10
# QUEUE_AGENT_CONCURRENCY=5

# Scaling
# BACKEND_REPLICAS=1
# QUEUE_WORKER_REPLICAS=2
# QUEUE_AGENT_REPLICAS=2
# UVICORN_WORKERS=4

# Resource limits (Docker)
# APP_CPU_LIMIT=2.0
# APP_MEMORY_LIMIT=2G
# APP_CPU_RESERVATION=0.5
# APP_MEMORY_RESERVATION=512M

# ClickHouse (request logging, optional)
# CLICKHOUSE_HOST=clickhouse
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=sinas
# CLICKHOUSE_RETENTION_DAYS=90
# CLICKHOUSE_HOT_RETENTION_DAYS=30

# ClickHouse S3 tiered storage (optional)
# CLICKHOUSE_S3_ENDPOINT=https://s3.amazonaws.com
# CLICKHOUSE_S3_BUCKET=my-bucket
# CLICKHOUSE_S3_ACCESS_KEY_ID=
# CLICKHOUSE_S3_SECRET_ACCESS_KEY=
# CLICKHOUSE_S3_REGION=us-east-1

# Declarative config (GitOps)
# CONFIG_FILE=config/my-config.yaml
# AUTO_APPLY_CONFIG=false

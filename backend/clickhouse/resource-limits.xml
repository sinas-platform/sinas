<clickhouse>
    <!-- Cap ClickHouse memory for small VPS deployments -->
    <!-- max_server_memory_usage: hard limit on total server memory (512MB) -->
    <max_server_memory_usage>536870912</max_server_memory_usage>

    <!-- Limit per-query memory to 256MB -->
    <profiles>
        <default>
            <max_memory_usage>268435456</max_memory_usage>
            <max_bytes_before_external_group_by>134217728</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>134217728</max_bytes_before_external_sort>
        </default>
    </profiles>

    <!-- Reduce background thread pools to save memory -->
    <background_pool_size>2</background_pool_size>
    <background_merges_mutations_concurrency_ratio>1</background_merges_mutations_concurrency_ratio>
    <background_schedule_pool_size>2</background_schedule_pool_size>
    <background_common_pool_size>2</background_common_pool_size>
    <background_move_pool_size>1</background_move_pool_size>
    <background_fetches_pool_size>1</background_fetches_pool_size>

    <!-- Limit concurrent connections -->
    <max_connections>64</max_connections>

    <!-- Reduce mark cache (default is 5GB) -->
    <mark_cache_size>134217728</mark_cache_size>
</clickhouse>
